{
  "compilerOptions": {
    "composite": true,
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out/main",
    "types": ["node", "electron-vite/node"],
    "paths": {
      "@shared/*": ["./shared/*"]
    }
  },
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "shared/**/*"]
}
